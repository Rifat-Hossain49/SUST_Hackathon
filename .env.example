# QueueStorm Investigator — environment variables (no real secrets here).
# The service runs fully WITHOUT any of these; all have safe defaults.

# Endpoint + service identity
# MAIN_ENDPOINT=/analyze-ticket
# APP_NAME=queuestorm-investigator
# APP_VERSION=1.0.0

# Port (most PaaS hosts inject this automatically)
# PORT=8000

# Flag a case for human review at/above this BDT amount ("high value cases")
# HIGH_VALUE_THRESHOLD=50000

# ---- Optional LLM polish (OFF by default) --------------------------------
# Leave USE_LLM=false to run 100% rule-based (no API key, no cost, fastest).
# USE_LLM=false
# ANTHROPIC_API_KEY=          # set ONLY in the deploy environment, never commit
# MODEL_NAME=claude-haiku-4-5
# LLM_TIMEOUT_SECONDS=4.0
# LLM_MAX_TOKENS=600
