# Copy to .env for local dev, or set these in your host's environment at deploy
# time (Render/Railway/Fly/EC2/Poridhi). NEVER commit a real key.

# Path of the main analysis endpoint — set to match the official Problem Statement.
MAIN_ENDPOINT=/analyze

# --- Optional LLM augmentation (off by default; rules work without it) ---
USE_LLM=false
ANTHROPIC_API_KEY=
MODEL_NAME=claude-haiku-4-5
LLM_TIMEOUT_SECONDS=4.0
LLM_MAX_TOKENS=512

# Reasoning knob
ESCALATE_CONFIDENCE_BELOW=0.55

# Server port (most platforms inject their own PORT).
PORT=8000
